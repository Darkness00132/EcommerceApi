@using Application.EmailModels
@model ResetPasswordModel

@{
    var currentYear = DateTime.UtcNow.Year;
    var previewText = "Use this secure link to reset your Ecommerce account password.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1" />

    <meta name="x-apple-disable-message-reformatting" />

    <title>Reset your password</title>

    <style>
        body,
        table,
        td,
        a {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table,
        td {
            mso-table-lspace: 0;
            mso-table-rspace: 0;
        }

        table {
            border-collapse: collapse !important;
        }

        body {
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            background-color: #f3f4f6;
        }

        .email-container {
            width: 100%;
            max-width: 600px;
        }

        .email-card {
            border: 1px solid #e5e7eb;
            border-radius: 16px;
        }

        .email-content {
            padding: 40px;
        }

        .button:hover {
            background-color: #1d4ed8 !important;
        }

        .fallback-link {
            color: #2563eb;
            text-decoration: underline;
            word-break: break-all;
        }

        @@media only screen and (max-width: 620px) {
            .email-wrapper {
                padding: 24px 12px !important;
            }

            .email-content {
                padding: 28px 20px !important;
            }

            .email-heading {
                font-size: 24px !important;
                line-height: 1.3 !important;
            }

            .button-container,
            .button-container td,
            .button {
                width: 100% !important;
            }

            .button {
                box-sizing: border-box;
                text-align: center !important;
            }
        }
    </style>
</head>

<body>
    <!-- Preview text shown by many email clients. -->
    <div style="
        display:none;
        max-height:0;
        max-width:0;
        overflow:hidden;
        opacity:0;
        color:transparent;
        line-height:1px;
        font-size:1px;">
        @previewText
    </div>

    <table
        role="presentation"
        width="100%"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="
            width:100%;
            background-color:#f3f4f6;">

        <tr>
            <td
                class="email-wrapper"
                align="center"
                style="padding:40px 16px;">

                <table
                    role="presentation"
                    class="email-container"
                    width="600"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                    style="
                        width:100%;
                        max-width:600px;
                        margin:0 auto;">

                    <!-- Brand -->
                    <tr>
                        <td
                            align="center"
                            style="padding:0 0 24px;">

                            <span style="
                                font-family:Arial,Helvetica,sans-serif;
                                font-size:22px;
                                line-height:1.3;
                                font-weight:700;
                                color:#111827;">
                                Ecommerce
                            </span>
                        </td>
                    </tr>

                    <!-- Main card -->
                    <tr>
                        <td
                            class="email-card"
                            style="
                                background-color:#ffffff;
                                border:1px solid #e5e7eb;
                                border-radius:16px;
                                overflow:hidden;">

                            <!-- Top accent -->
                            <table
                                role="presentation"
                                width="100%"
                                cellpadding="0"
                                cellspacing="0"
                                border="0">

                                <tr>
                                    <td
                                        height="6"
                                        style="
                                            height:6px;
                                            background-color:#2563eb;
                                            font-size:0;
                                            line-height:0;">
                                        &nbsp;
                                    </td>
                                </tr>
                            </table>

                            <table
                                role="presentation"
                                width="100%"
                                cellpadding="0"
                                cellspacing="0"
                                border="0">

                                <tr>
                                    <td
                                        class="email-content"
                                        style="
                                            padding:40px;
                                            font-family:Arial,Helvetica,sans-serif;">

                                        <h1
                                            class="email-heading"
                                            style="
                                                margin:0 0 20px;
                                                font-family:Arial,Helvetica,sans-serif;
                                                font-size:28px;
                                                line-height:1.3;
                                                font-weight:700;
                                                color:#111827;">
                                            Reset your password
                                        </h1>

                                        <p style="
                                            margin:0 0 16px;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:16px;
                                            line-height:1.7;
                                            color:#374151;">
                                            Hi @Model.FirstName,
                                        </p>

                                        <p style="
                                            margin:0 0 28px;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:16px;
                                            line-height:1.7;
                                            color:#4b5563;">
                                            We received a request to reset the password
                                            for your Ecommerce account. Select the button
                                            below to create a new password.
                                        </p>

                                        <!-- Reset button -->
                                        <table
                                            role="presentation"
                                            class="button-container"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0">

                                            <tr>
                                                <td
                                                    align="center"
                                                    bgcolor="#2563eb"
                                                    style="border-radius:8px;">

                                                    <a
                                                        class="button"
                                                        href="@Model.ResetLink"
                                                        target="_blank"
                                                        style="
                                                            display:inline-block;
                                                            padding:14px 28px;
                                                            border:1px solid #2563eb;
                                                            border-radius:8px;
                                                            background-color:#2563eb;
                                                            font-family:Arial,Helvetica,sans-serif;
                                                            font-size:16px;
                                                            line-height:1.2;
                                                            font-weight:700;
                                                            color:#ffffff;
                                                            text-decoration:none;">
                                                        Reset password
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>

                                        <p style="
                                            margin:28px 0 8px;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:14px;
                                            line-height:1.6;
                                            color:#6b7280;">
                                            If the button does not work, copy and paste
                                            this link into your browser:
                                        </p>

                                        <p style="
                                            margin:0;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:14px;
                                            line-height:1.6;
                                            word-break:break-all;">

                                            <a
                                                class="fallback-link"
                                                href="@Model.ResetLink"
                                                target="_blank"
                                                style="
                                                    color:#2563eb;
                                                    text-decoration:underline;
                                                    word-break:break-all;">
                                                @Model.ResetLink
                                            </a>
                                        </p>

                                        <hr style="
                                            margin:32px 0;
                                            border:0;
                                            border-top:1px solid #e5e7eb;" />

                                        <!-- Security notice -->
                                        <table
                                            role="presentation"
                                            width="100%"
                                            cellpadding="0"
                                            cellspacing="0"
                                            border="0"
                                            style="
                                                width:100%;
                                                background-color:#f9fafb;
                                                border:1px solid #e5e7eb;
                                                border-radius:8px;">

                                            <tr>
                                                <td style="padding:16px;">
                                                    <p style="
                                                        margin:0 0 6px;
                                                        font-family:Arial,Helvetica,sans-serif;
                                                        font-size:14px;
                                                        line-height:1.5;
                                                        font-weight:700;
                                                        color:#374151;">
                                                        Didn't request this?
                                                    </p>

                                                    <p style="
                                                        margin:0;
                                                        font-family:Arial,Helvetica,sans-serif;
                                                        font-size:13px;
                                                        line-height:1.6;
                                                        color:#6b7280;">
                                                        You can safely ignore this email.
                                                        Your password will remain unchanged
                                                        unless the reset link is used.
                                                    </p>
                                                </td>
                                            </tr>
                                        </table>

                                        <p style="
                                            margin:24px 0 0;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:13px;
                                            line-height:1.6;
                                            color:#6b7280;">
                                            For your security, never forward this email
                                            or share this password-reset link with anyone.
                                        </p>

                                        <p style="
                                            margin:24px 0 0;
                                            font-family:Arial,Helvetica,sans-serif;
                                            font-size:14px;
                                            line-height:1.6;
                                            color:#4b5563;">
                                            Thanks,<br />

                                            <strong style="color:#111827;">
                                                The Ecommerce Team
                                            </strong>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td
                            align="center"
                            style="
                                padding:24px 16px 0;
                                font-family:Arial,Helvetica,sans-serif;">

                            <p style="
                                margin:0;
                                font-size:12px;
                                line-height:1.6;
                                color:#9ca3af;">
                                This is an automated message. Please do not reply.
                            </p>

                            <p style="
                                margin:6px 0 0;
                                font-size:12px;
                                line-height:1.6;
                                color:#9ca3af;">
                                &copy; @currentYear Ecommerce. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>